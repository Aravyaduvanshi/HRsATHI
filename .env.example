# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# WARNING: Never expose this key client-side — server routes and workers only
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Clerk ─────────────────────────────────────────────────────────────────────
# Found in: clerk.com → Your Application → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── Voyage AI ─────────────────────────────────────────────────────────────────
# Found in: dash.voyageai.com → API Keys
VOYAGE_API_KEY=pa-...

# ── Groq (LLM for parsing & scoring) ────────────────────────────────────────
# Found in: console.groq.com → API Keys  (free tier available)
GROQ_API_KEY=gsk_...
# Model for parsing and scoring — llama-3.3-70b-versatile recommended
# Alternatives: llama-3.1-8b-instant (faster), mixtral-8x7b-32768
GROQ_MODEL=llama-3.3-70b-versatile

# ── Upstash Redis (BullMQ transport) ─────────────────────────────────────────
# Found in: console.upstash.com → Your Database → REST API
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...
# ioredis connection string (used by BullMQ worker, not the REST client)
UPSTASH_REDIS_URL=rediss://:yourtoken@your-db.upstash.io:6380

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Secret used to validate webhook calls from the worker back to Next.js
WORKER_WEBHOOK_SECRET=a-long-random-secret-string
